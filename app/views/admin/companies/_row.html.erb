<tr id="<%= dom_id(resource) %>">
  <td class="cell-data cell-data--number"><%= resource.id %></td>
  <td class="cell-data cell-data--string"><%= resource.name %></td>
  <td class="cell-data cell-data--string"><%= resource.description %></td>
  <td class="cell-data cell-data--date_time"><%= resource.updated_at&.strftime("%Y/%m/%d %H:%M") %></td>
  <td class="cell-label--action-button">
    <%= link_to t("administrate.actions.edit"),
        edit_admin_company_path(resource),
        data: { turbo_stream: true },
        class: "action-edit" %>
  </td>
  <td class="cell-label--action-button">
    <%= button_to t("administrate.actions.destroy"), admin_company_path(resource),
        class: "link link--danger",
        method: :delete,
        data: { turbo_confirm: t("administrate.actions.confirm") } %>
  </td>
</tr>
